<?xml version="1.0" encoding="UTF-8"?>
<hoot-overrides>
  <game archive="xak68snd">
    <option name="reset_on_track" value="1"/>
    <asset file="SYOKI2.BGM" transform="opmdrv-compact-voice"/>
    <voicebank id="B" file="SYOKI2_B.BGM" offset="0x20000" transform="opmdrv-compact-voice"/>
    <voicebank id="D" file="SYOKI2_D.BGM" offset="0x20000" transform="opmdrv-compact-voice"/>

    <track code="0x02" voicebank="B"/>
    <track code="0x08" voicebank="B"/>
    <track code="0x09" voicebank="B"/>
    <track code="0x14" voicebank="B"/>
    <track code="0x16" voicebank="B"/>
    <track code="0x23" voicebank="B"/>

    <track code="0x03" voicebank="D"/>
    <track code="0x0c" voicebank="D"/>
    <track code="0x0d" voicebank="D"/>
    <track code="0x0f" voicebank="D"/>
    <track code="0x13" voicebank="D"/>
    <track code="0x15" voicebank="D"/>
    <track code="0x17" voicebank="D"/>
    <track code="0x1e" voicebank="D"/>
    <track code="0x21" voicebank="D"/>
    <track code="0x22" voicebank="D"/>
    <track code="0x29" voicebank="D"/>
  </game>
  <game archive="ngear68snd">
    <!-- Neural Gear starts from Hoot's standalone MFP bootstrap state. -->
    <option name="mfp_timer_divider" value="100"/>
    <option name="mfp_initial_ierb" value="0x2e"/>
    <option name="mfp_initial_imrb" value="0x2e"/>
    <option name="mfp_sound_timer" value="2"/>
  </game>
</hoot-overrides>
